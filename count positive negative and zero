#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int arr[n];
    int pos=0, neg=0, zero=0;

    for(int i=0;i<n;i++) {
        cin >> arr[i];

        if(arr[i] > 0)
            pos++;
        else if(arr[i] < 0)
            neg++;
        else
            zero++;
    }

    cout << "Positive = " << pos << endl;
    cout << "Negative = " << neg << endl;
    cout << "Zero = " << zero;
}z