#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int arr[n], copy[n];

    for(int i=0;i<n;i++) {
        cin >> arr[i];
        copy[i] = arr[i];
    }

    cout << "Copied Array:" << endl;

    for(int i=0;i<n;i++)
        cout << copy[i] << " ";
}